+  def set_eval_command(self, command: torch.Tensor | None) -> None:
+      """Set or clear eval-time fixed velocity command override.
+
+      用途：
+        - 训练时不调用这个函数，环境继续按原来的随机 command 流程运行。
+        - 测试时由外部脚本在每一步传入固定 command,
+          从而实现“训练随机、评测固定”的两套模式共存。
+
+      参数:
+        command:
+          - None: 关闭 eval override,恢复原始 command 逻辑。
+          - Tensor: 启用 eval override,要求 shape 为 [num_envs, 3],
+            每一行对应一个环境的 [vx, vy, wz]。
+      """
+      if command is None:
+          # 关闭固定 command 覆盖，恢复默认随机/heading/standing 逻辑。
+          self._eval_override_enabled = False
+          self._eval_override_command = None
+      else:
+          # 开启固定 command 覆盖。
+          # 这里将输入 tensor 移到当前 device，避免后面在 compute() 中发生设备不一致错误。
+          self._eval_override_enabled = True
+          self._eval_override_command = command.to(self.device)
+
